  },
  "schedule": {
    "day_of_week": "monday",
    "time": "13:42",
    "timezone": "UTC"
  },
  "newsletter": {
    "newsletter_name": "AI Research Insights",
    "include_abstract_snippets": true,
    "max_papers_in_newsletter": 3,
    "include_subdomain_breakdown": true
  },
  "monitoring": {
    "enable_logging": true,
    "log_retention_days": 8,
    "send_error_notifications": true
  }
